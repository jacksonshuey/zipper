# Anthropic — used by HaikuRouter and the HTTP API.
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown).
# ZIPPER_MODEL=claude-haiku-4-5
# ZIPPER_TIMEOUT_MS=8000
# ZIPPER_MAX_TOKENS=256
# ZIPPER_WORKSPACE_KEY=default

# HTTP API: path for the SQLite store (default in-memory).
# ZIPPER_DB_PATH=./zipper.db

# HTTP API auth: comma-separated client bearer tokens. Required to serve /v1/*
# routes. Without it (and without the opt-out below) those routes return 503.
# ZIPPER_API_KEYS=client-one-token,client-two-token

# Explicitly run the API open (no auth) — only behind your own gateway/proxy.
# ZIPPER_ALLOW_NO_AUTH=1

# HTTP API rate limit (per caller). Unset/<=0 means unlimited.
# ZIPPER_RATE_LIMIT=120
# ZIPPER_RATE_WINDOW_S=60
